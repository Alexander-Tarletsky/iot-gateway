# PROFILE=native — run on host or Docker Linux with network_mode: host
# PROFILE=docker-mac — Docker Desktop on macOS (use docker-compose.mac.yml)

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=home/esp32c3/sensors/aht10
MQTT_USERNAME=admin
MQTT_PASSWORD=changeme
MQTT_CLIENT_ID=iot-gateway-worker

# Odoo Climate Monitor API (default port 8069)
API_BASE_URL=http://127.0.0.1:8069
API_ENDPOINT=/climate/api/v1/readings
CLIMATE_API_KEY=changeme
DEVICE_ID=esp32

HTTP_TIMEOUT_SEC=10
HTTP_RETRY_COUNT=2
HTTP_RETRY_DELAY_SEC=1

LOG_LEVEL=INFO

# --- PROFILE=docker-mac (uncomment and use docker-compose.mac.yml) ---
# MQTT_HOST=host.docker.internal
# API_BASE_URL=http://host.docker.internal:8069
